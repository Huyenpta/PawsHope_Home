{
  "name": "pawshope-home",
  "private": true,
  "description": "Monorepo: frontend/ (Vite) và backend/ (Spring Boot) cùng cấp trong PawsHope_Home",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "backend:dev": "node scripts/run-backend.cjs spring-boot:run",
    "backend:package": "node scripts/run-backend.cjs -q clean package -DskipTests"
  }
}
